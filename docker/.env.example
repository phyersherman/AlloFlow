# AlloFlow "School Box" — Environment Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Firebase configuration is OPTIONAL — only needed for:
#   - Live teacher-student sessions
#   - Cloud backup
#   - Student authentication
#
# Without Firebase, AlloFlow works fully offline with local AI.

# ─── Firebase (Optional) ────────────────────────────────────────────
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# ─── Data Backend ────────────────────────────────────────────────
# 'auto'       = try PocketBase first, then Firebase, then localStorage
# 'pocketbase' = force PocketBase (requires running PocketBase server)
# 'firebase'   = force Firebase (requires Firebase config above)
# 'local'      = localStorage only (fully offline, no server needed)
DATA_BACKEND=auto
POCKETBASE_URL=http://localhost:8090
